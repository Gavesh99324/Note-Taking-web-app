# Server Configuration
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/notesapp
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/notesapp

# JWT Secret Keys (Generate strong random strings for production)
JWT_ACCESS_SECRET=your-access-token-secret-key-change-this-in-production
JWT_REFRESH_SECRET=your-refresh-token-secret-key-change-this-in-production
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Security
BCRYPT_ROUNDS=10
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
